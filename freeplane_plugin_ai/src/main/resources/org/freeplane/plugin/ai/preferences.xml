<?xml version="1.0" encoding="UTF-8"?><preferences_structure xmlns="http://freeplane.sf.net/ui/preferences/1.0">
<tabbed_pane>
<tab name="plugins">
    <separator name="ai">
        <boolean name="ai_edits_state_icon_visible"/>
        <boolean name="ai_edits_persistence_enabled"/>
        <boolean name="ai_chat_shows_tool_calls"/>
        <number name="ai_chat_font_scaling" min="25" max="400" />
        <number name="ai_chat_memory_maximum_token_count" min="2048" max="1048576" />
        <radiobuttons name="ai_chat_token_counter_mode">
            <choice value="hidden" text="OptionPanel.ai_chat_token_counter_mode.hidden"/>
            <choice value="context" text="OptionPanel.ai_chat_token_counter_mode.context"/>
            <choice value="total" text="OptionPanel.ai_chat_token_counter_mode.total"/>
            <choice value="model_response" text="OptionPanel.ai_chat_token_counter_mode.model_response"/>
        </radiobuttons>
        <boolean name="ai_unfolds_parents_on_create"/>
        <textbox name="ai_system_message" lines="5"/>
        <boolean name="ai_mcp_server_enabled"/>
        <number name="ai_mcp_server_port" min="1024" max="65535" />
        <secret name="ai_mcp_token"/>
        <string name="ai_openrouter_service_address"/>
        <secret name="ai_openrouter_key"/>
        <textbox name="ai_openrouter_model_allowlist" lines="5"/>
        <string name="ai_gemini_service_address"/>
        <secret name="ai_gemini_key"/>
        <textbox name="ai_gemini_model_list" lines="5"/>
        <string name="ai_ollama_service_address"/>
        <secret name="ai_ollama_api_key"/>
        <textbox name="ai_ollama_model_allowlist" lines="5"/>
        <separator name="ai_domestic_providers"/>
        <string name="ai_dashscope_service_address"/>
        <secret name="ai_dashscope_key"/>
        <textbox name="ai_dashscope_model_list" lines="3"/>
        <string name="ai_ernie_service_address"/>
        <secret name="ai_ernie_key"/>
        <textbox name="ai_ernie_model_list" lines="3"/>
    </separator>
</tab>
</tabbed_pane>
</preferences_structure>
